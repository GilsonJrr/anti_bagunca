# Copie para .env na raiz do projeto e preencha com os dados do Firebase (Console > Configurações do projeto).
# Reinicie o bundler do Expo após alterar.
#
# Builds na nuvem (EAS): defina as mesmas variáveis EXPO_PUBLIC_* no projeto em
# https://expo.dev (Environment variables) ou use `eas env:create`, para o app.config.js
# receber Firebase/Google nas builds de produção.
#
# Android nativo: o arquivo credentials/android/google-services.json vem do Firebase
# (Configurações do projeto > Seu app Android > google-services.json).

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Realtime Database — URL em Firebase Console > Realtime Database (ex.: https://SEU_PROJETO-default-rtdb.firebaseio.com)
EXPO_PUBLIC_FIREBASE_DATABASE_URL=

# Login com Google (Firebase Auth + Google Cloud OAuth). Opcional.
# useIdTokenAuthRequest: use o Web client ID; em iOS/Android use também os clientes nativos.
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
